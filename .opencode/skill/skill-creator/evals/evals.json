{
  "skill": "skill-creator",
  "version": "1.0.0",
  "test_cases": [
    {
      "id": "defines-use-cases-first",
      "description": "Should ask for use cases before writing skill",
      "input": "Create a skill for our frontend design process",
      "expected_output_contains": ["use case", "trigger", "workflow"],
      "expected_output_excludes": ["here is the skill", "SKILL.md"]
    },
    {
      "id": "creates-evals",
      "description": "Should create evals as part of the skill creation",
      "input": "Build a skill for code review",
      "expected_output_contains": ["evals", "trigger_evals", "test"],
      "expected_output_excludes": ["skip evals", "no tests needed"]
    },
    {
      "id": "generates-frontmatter",
      "description": "Should generate proper YAML frontmatter",
      "input": "Help me create a skill for API documentation",
      "expected_output_contains": ["name:", "description:", "version:", "user-invocable"],
      "expected_output_excludes": ["invalid yaml", "syntax error"]
    }
  ]
}
