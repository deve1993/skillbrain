{
  "skill": "skill-eval",
  "version": "1.0.0",
  "test_cases": [
    {
      "id": "locates-evals",
      "description": "Should locate and read evals files",
      "input": "Test the brainstorming skill",
      "expected_output_contains": ["trigger_evals", "evals.json", "test cases"],
      "expected_output_excludes": ["not found", "error"]
    },
    {
      "id": "validates-triggers",
      "description": "Should validate trigger accuracy",
      "input": "Run evals for my-skill",
      "expected_output_contains": ["should_trigger", "should_not_trigger", "coverage"],
      "expected_output_excludes": ["skip validation"]
    },
    {
      "id": "generates-report",
      "description": "Should generate comprehensive eval report",
      "input": "Verify skill quality",
      "expected_output_contains": ["REPORT", "PASS", "recommendations"],
      "expected_output_excludes": ["no report"]
    }
  ]
}
