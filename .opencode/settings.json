{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/load_project_context.sh",
            "timeout": 15,
            "statusMessage": "Loading SkillBrain Cortex briefing"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/skill-apply-hook.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
