{
  "name": "@skillbrain/storage",
  "version": "0.1.0",
  "description": "SkillBrain storage layer — SQLite-backed memories, skills, sessions, OAuth, projects.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc && rm -rf dist/migrations && mkdir -p dist && cp -r src/migrations dist/migrations",
    "dev": "tsc --watch",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "backfill:embeddings": "tsx scripts/backfill-embeddings.ts"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.5.0",
    "better-sqlite3": "^11.8.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.1"
  },
  "author": "Daniel De Vecchi",
  "license": "AGPL-3.0-or-later"
}
