{
  "name": "codegraph",
  "version": "0.1.0",
  "description": "Code intelligence knowledge graph — AST parsing, impact analysis, semantic search, MCP server. Zero heavy dependencies.",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "codegraph": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "analyze": "node dist/cli.js analyze",
    "mcp": "node dist/cli.js mcp",
    "import:skills": "tsx scripts/bulk-import-skills.ts",
    "backfill:edges": "tsx scripts/backfill-edges.ts",
    "recategorize:other": "tsx scripts/recategorize-other-skills.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@skillbrain/storage": "workspace:*",
    "better-sqlite3": "^11.8.1",
    "commander": "^13.1.0",
    "express": "^5.2.1",
    "gray-matter": "^4.0.3",
    "ignore": "^7.0.5",
    "nodemailer": "^8.0.7",
    "ts-morph": "^25.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.1"
  },
  "author": "Daniel De Vecchi",
  "license": "AGPL-3.0-or-later"
}
