# Pixarts CMS Configuration
# Copy to .env.local and fill in values

# ===========================================
# CMS (Payload) - Required for tenant-setup
# ===========================================
PAYLOAD_API_URL=https://cms.pixarts.eu/api
PAYLOAD_API_TOKEN=your-admin-api-token

# ===========================================
# GitHub - Required for site-scaffolder
# ===========================================
GITHUB_ORG=deve1993
# Note: gh CLI must be authenticated

# ===========================================
# Coolify - Required for site-deployer
# ===========================================
COOLIFY_URL=https://coolify.pixarts.eu
COOLIFY_TOKEN=your-coolify-api-token

# ===========================================
# Client Site Template (copied to each project)
# ===========================================
# These are template values - actual values set per-project

# CMS
# NEXT_PUBLIC_CMS_URL=https://cms.pixarts.eu
# NEXT_PUBLIC_TENANT_SLUG=client-slug

# Site
# NEXT_PUBLIC_SITE_URL=https://client-domain.com
# NEXT_PUBLIC_SITE_NAME=Client Name

# Revalidation
# REVALIDATION_SECRET=generate-32-char-random-string

# Locales
# NEXT_PUBLIC_DEFAULT_LOCALE=it
# NEXT_PUBLIC_LOCALES=it,en
