  "mcp": {
    "shadcn": {
      "type": "local",
      "command": [
        "npx",
        "shadcn@latest",
        "mcp"
      ],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-playwright"
      ],
      "enabled": true
    },
    "github": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-github@2025.4.8"
      ],
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_TOKEN}"
      },
      "enabled": true
    },
    "memory": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "enabled": true
    },
    "fetch": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-fetch"
      ],
      "enabled": true
    },
    "stocky": {
      "type": "local",
      "command": [
        "/Users/dan/Desktop/progetti-web/Struttura principale Opencode/mcp-servers/stocky-src/.venv/bin/python3.12",
        "/Users/dan/Desktop/progetti-web/Struttura principale Opencode/mcp-servers/stocky-src/stocky_mcp.py"
      ],
      "environment": {
        "UNSPLASH_ACCESS_KEY": "{env:UNSPLASH_ACCESS_KEY}"
      },
      "enabled": true
    },
    "n8n-mcp": {
      "type": "local",
      "command": [
        "npx",
        "n8n-mcp"
      ],
      "environment": {
        "MCP_MODE": "stdio",
        "LOG_LEVEL": "error",
        "DISABLE_CONSOLE_OUTPUT": "true",
        "N8N_API_URL": "https://n8n-auto.fl1.it",
        "N8N_API_KEY": "{env:N8N_API_KEY}"
      },
      "enabled": true
    },
    "design-copier": {
