      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst textBlock = response.content?.find(b => b.type === 'text');\nconst text = textBlock?.text || '';\nconst match = text.match(/\\{[\\s\\S]*\"pending\"[\\s\\S]*\\}/);\nlet pending = [];\ntry { pending = match ? JSON.parse(match[0]).pending : []; } catch(e) {}\nif (pending.length === 0) {\n  return [{ json: { text: '\ud83d\udccb Nessuna proposal pending.\\n\\nUsa /skill-sync per generarne di nuove.', reply_markup: null } }];\n}\nconst lines = pending.map(p => `\u2022 *${p.skill}*: _${p.preview}_`);\nconst keyboard = pending.map(p => [\n  { text: '\u2705 ' + p.skill, callback_data: 'approve_' + p.skill },\n  { text: '\u274c', callback_data: 'reject_' + p.skill }\n]);\nreturn [{ json: {\n  text: '\ud83d\udccb *Proposals pending* (' + pending.length + '):\\n\\n' + lines.join('\\n'),\n  reply_markup: { inline_keyboard: keyboard }\n} }];"
