    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || {};\nconst text = body.message?.text || '';\nconst callbackData = body.callback_query?.data || '';\nconst callbackQueryId = body.callback_query?.id || null;\nlet route = 'unknown', skill = null;\nif (text === '/skill-sync') { route = 'sync'; }\nelse if (text === '/pending') { route = 'pending'; }\nelse if (callbackData.startsWith('approve_')) { route = 'approve'; skill = callbackData.replace('approve_', ''); }\nelse if (callbackData.startsWith('reject_')) { route = 'reject'; skill = callbackData.replace('reject_', ''); }\nreturn [{ json: { route, skill, callback_query_id: callbackQueryId } }];"
      },
