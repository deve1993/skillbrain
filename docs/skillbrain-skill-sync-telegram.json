    {
      "parameters": {
        "jsCode": "const proposals = $input.first().json.proposals;\nconst lines = proposals.map(p => `\u2022 *${p.skill}* (${p.memories} memorie)`);\nconst keyboard = proposals.map(p => [\n  { text: '\u2705 ' + p.skill, callback_data: 'approve_' + p.skill },\n  { text: '\u274c scarta', callback_data: 'reject_' + p.skill }\n]);\nreturn [{ json: {\n  text: '\ud83e\udde0 *Skill Sync completato*\\n\\n\ud83d\udccb ' + proposals.length + ' proposte pending:\\n' + lines.join('\\n') + '\\n\\nSeleziona cosa fare:',\n  reply_markup: { inline_keyboard: keyboard }\n} }];"
      },
      "id": "node-build-msg-proposals",
      "name": "Build Proposals Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
